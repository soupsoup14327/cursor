{
  "name": "module-battle",
  "version": "1.0.0",
  "description": "Module battle — пошаговый бой в духе D&D",
  "main": "electron-main.js",
  "private": true,
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64"
  },
  "devDependencies": {
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.modulebattle.game",
    "productName": "Module battle",
    "files": [
      "index.html",
      "script.js",
      "style.css",
      "electron-main.js"
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  }
}
